# Variáveis de Ambiente - Exemplo
# Copie este arquivo para .env e preencha com seus valores

# Base URLs
BASE_URL=https://front.serverest.dev
API_URL=https://serverest.dev/api

# Usuário de teste (use credenciais que não são sensíveis)
TEST_USER_EMAIL=usuario.teste@example.com
TEST_USER_PASSWORD=SenhaTest@123

# Admin de teste (para testes de administrador)
TEST_ADMIN_EMAIL=admin.teste@example.com
TEST_ADMIN_PASSWORD=AdminSenha@123

# Configuração do Cypress
CYPRESS_BASE_URL=https://front.serverest.dev
CYPRESS_API_URL=https://serverest.dev/api
